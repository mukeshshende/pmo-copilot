# Copy this file to k8s/secret.yaml and fill in your actual Langfuse API keys
# Never commit secret.yaml to git — it is in .gitignore
apiVersion: v1
kind: Secret
metadata:
  name: pmo-secrets
  namespace: pmo-copilot
type: Opaque
stringData:
  LANGFUSE_PUBLIC_KEY: "pk-lf-your-public-key-here"
  LANGFUSE_SECRET_KEY: "sk-lf-your-secret-key-here"
