# PMO Copilot — Environment Configuration Template
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Ollama (Windows laptop running Ollama) ────────────────
OLLAMA_BASE_URL=http://<windows-laptop-ip>:11434
OLLAMA_API_BASE=http://<windows-laptop-ip>:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Data paths (local dev) ────────────────────────────────
# These are overridden by K3s ConfigMap when running in K3s
DATA_DIR=/home/<your-username>/pmo-copilot/data
CHROMA_DIR=/home/<your-username>/pmo-copilot/memory/chroma_db

# ── Langfuse (running in K3s) ─────────────────────────────
# External URL for browser access
LANGFUSE_HOST=http://<dell-ip>:30300
# Get these from Langfuse UI → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
